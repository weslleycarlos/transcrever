{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcrever",
  "version": "0.1.0",
  "identifier": "br.local.transcrever",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File scripts/ensure-model.ps1 && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Transcrever",
        "width": 1280,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "models/": "./models/",
      "binaries/": "./binaries/"
    }
  }
}
